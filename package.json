{
	"name": "pdf-lab-monorepo",
	"private": true,
	"description": "Convert PDFs to PDF/A-1b, PDF/A-2b, or PDF/A-3b",
	"homepage": "https://gflohr.github.io/pdf-lab/#readme",
	"keywords": [
		"PDF",
		"PDF/A",
		"PDF/A-1b",
		"PDF/A-2b",
		"PDF/A-3b",
		"Factur-X",
		"ZUGFeRD",
		"nodejs",
		"typescript"
	],
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"build": "pnpm run -r build",
		"check": "biome check",
		"check:fix": "biome check --write",
		"check:staged": "biome check --staged --write --no-errors-on-unmatched",
		"start": "pnpm --filter pdf-lab run start --workspace-root",
		"start:dev": "pnpm --filter pdf-lab run start:dev",
		"test": "pnpm -r run test",
		"test:cov": "pnpm -r run test:cov",
		"test:cov-changed": "pnpm -r run test:cov-changed",
		"test:watch": "pnpm -r run test:watch",
		"aggregate-coverage": "node scripts/aggregate-coverage.mjs",
		"release": "HUSKY=0 pnpm changeset publish",
		"prerelease": "pnpm install && pnpm run build && pnpm run test",
		"check:clean": "./check-clean && pnpm -r --parallel run check:clean",
		"prepublish": "pnpm run check:clean && pnpm run test",
		"clean": "pnpm -r --parallel run clean",
		"prepare": "husky",
		"preinstall": "npx only-allow pnpm",
		"gen": "pnpm run gen:agl",
		"gen:agl": "tsx scripts/gen-tables.ts agl>packages/pdf-lab-core/src/agl.ts",
		"postgen:agl": "biome check --write packages/pdf-lab-core/src/agl.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@changesets/cli": "^2.30.0",
		"@tsconfig/recommended": "^1.0.13",
		"@types/node": "^25.6.0",
		"@types/unicode-name": "^1.1.0",
		"changeset": "^0.2.6",
		"glob": "^13.0.6",
		"husky": "^9.1.7",
		"js-yaml": "^4.1.1",
		"pnpm": "^10.33.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"unicode-name": "^1.1.0",
		"vitest": "^4.1.4"
	}
}
