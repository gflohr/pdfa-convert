{
	"files": [],
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"strict": true,
		"forceConsistentCasingInFileNames": true,
		"noUncheckedIndexedAccess": true,
		"esModuleInterop": true,
		"moduleResolution": "Node",
		"skipLibCheck": true,
		"declaration": true,
		"sourceMap": true,
		"rootDir": ".",
		"outDir": "dist",
		"paths": {
			"pdf-lab-core": ["./packages/pdf-lab-core/src"],
			"pdf-lab-core/*": ["./packages/pdf-lab-core/src/*"],
		},
		"types": ["node"]
	},
	"include": [],
	"exclude": ["node_modules", "dist"]
}
